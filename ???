-- 1. ULTIMATIVE REINIGUNG (Löscht ALLES Alte)
local function globalCleanup()
    _G.Flying = false
    _G.IsTransforming = false
    _G.DomainActive = false
    
    for _, ui in pairs(CoreGui:GetChildren()) do 
        if ui.Name:find("RW9") or ui.Name == "GodUI" then ui:Destroy() end 
    end
    
    if lp.Character then
        for _, v in pairs(lp.Character:GetChildren()) do
            if v.Name == "GodWings" or v.Name == "GodLabel" or v.Name == "OrbitStar" or v.Name == "GodTrail" then 
                v:Destroy() 
            end
        end
        local hum = lp.Character:FindFirstChild("Humanoid")
        if hum then
            hum.PlatformStand = false
            hum.WalkSpeed = 16
            hum.JumpPower = 50
        end
    end
    
    -- Lighting Reset
    Lighting.ClockTime = 14
    Lighting.Brightness = 2
    for _, effect in pairs(Lighting:GetChildren()) do
        if effect:IsA("PostProcessEffect") then effect:Destroy() end
    end
end
