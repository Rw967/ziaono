-- 5. INPUTS (MASSIV)
UserInputService.InputBegan:Connect(function(input, gpe)
    if gpe then return end
    
    -- [C] GOD BALL (FIXED)
    if input.KeyCode == Enum.KeyCode.C then
        local charging = true
        local p = mouse.Hit.p
        local ball = Instance.new("Part", workspace); ball.Shape = "Ball"; ball.Anchored = true; ball.CanCollide = false; ball.Position = p; ball.Color = Color3.new(1,0,0.8); ball.Material = "ForceField"
        task.spawn(function()
            local s = 0
            while charging and ball.Parent do
                s = math.min(s + 0.5, 35); ball.Size = Vector3.new(s,s,s)
                task.wait(0.05)
            end
        end)
        local stop; stop = UserInputService.InputEnded:Connect(function(i)
            if i.KeyCode == Enum.KeyCode.C then charging = false; createExplosion(ball.Position, ball.Color, 1.5); ball:Destroy(); stop:Disconnect() end
        end)

    -- [X] HEAVEN'S STRIKE
    elseif input.KeyCode == Enum.KeyCode.X then
        local target = mouse.Hit.p
        local bolt = Instance.new("Part", workspace); bolt.Size = Vector3.new(8, 1000, 8); bolt.Position = target + Vector3.new(0, 500, 0); bolt.Anchored = true; bolt.Color = Color3.new(1,1,1); bolt.Material = "Neon"
        createExplosion(target, Color3.new(1,1,1), 1.5); Debris:AddItem(bolt, 0.2)

    -- [K] DOMAIN EXPANSION
    elseif input.KeyCode == Enum.KeyCode.K then
        local domain = Instance.new("Part", workspace); domain.Shape = "Ball"; domain.Anchored = true; domain.CanCollide = false; domain.Position = lp.Character.HumanoidRootPart.Position
        domain.Color = Color3.new(0,0,0); domain.Material = "ForceField"; domain.Size = Vector3.new(1,1,1)
        TweenService:Create(domain, TweenInfo.new(1.5), {Size = Vector3.new(200, 200, 200)}):Play()
        task.delay(10, function() domain:Destroy() end)

    -- [Q] DASH
    elseif input.KeyCode == Enum.KeyCode.Q then
        lp.Character.HumanoidRootPart.CFrame = lp.Character.HumanoidRootPart.CFrame * CFrame.new(0, 0, -60)
        createExplosion(lp.Character.HumanoidRootPart.Position, Color3.new(1,1,1), 0.5)

    -- [Y] CEREMONY
    elseif input.KeyCode == Enum.KeyCode.Y then startCeremony()

    -- [L] SPEED
    elseif input.KeyCode == Enum.KeyCode.L then lp.Character.Humanoid.WalkSpeed = (lp.Character.Humanoid.WalkSpeed == 16) and 450 or 16

    -- [M] RESET
    elseif input.KeyCode == Enum.KeyCode.M then globalCleanup()
    end
end)

