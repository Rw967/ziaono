    local finalBolt = Instance.new("Part", workspace); finalBolt.Size = Vector3.new(15, 1000, 15); finalBolt.Position = hrp.Position; finalBolt.Anchored = true; finalBolt.Color = Color3.new(1,1,1); finalBolt.Material = "Neon"
