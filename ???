-- 3. GÖTTLICHE EFFEKTE
local function createExplosion(pos, color, scale)
    scale = scale or 1
    local exp = Instance.new("Explosion", workspace)
    exp.Position = pos; exp.BlastRadius = 30 * scale; exp.BlastPressure = 0
    
    local p = Instance.new("Part", workspace)
    p.Anchored = true; p.Shape = "Ball"; p.Position = pos; p.Size = Vector3.new(1,1,1)
    p.Color = color; p.Material = "Neon"; p.CanCollide = false
    
    TweenService:Create(p, TweenInfo.new(0.6), {Size = Vector3.new(50*scale, 50*scale, 50*scale), Transparency = 1}):Play()
    Debris:AddItem(p, 0.6)
end

