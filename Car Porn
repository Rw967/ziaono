-- Services
local UIS = game:GetService("UserInputService")
local TweenService = game:GetService("TweenService")
local RunService = game:GetService("RunService")
local StarterGui = game:GetService("StarterGui")
local Players = game:GetService("Players")

local player = Players.LocalPlayer
local camera = workspace.CurrentCamera
local isCinematic = false
local lastInputTime = tick()

-- UI für VOLLBILD-Schwarz (Absolute Abdeckung)
local screenGui = Instance.new("ScreenGui", player.PlayerGui)
screenGui.Name = "CinematicFade"
screenGui.IgnoreGuiInset = true
local fadeFrame = Instance.new("Frame", screenGui)
fadeFrame.Size = UDim2.new(1, 0, 1, 0)
fadeFrame.BackgroundColor3 = Color3.new(0, 0, 0)
fadeFrame.BackgroundTransparency = 1

-- Alle 7 Perspektiven für maximale Abwechslung
local offsets = {
	{pos = Vector3.new(12, 2, 0), move = "Orbit"},
	{pos = Vector3.new(0, 10, 2), move = "TopDown"},
	{pos = Vector3.new(-6, 1, -8), move = "ZoomIn"},
	{pos = Vector3.new(0, 1.5, -12), move = "Slide"},
	{pos = Vector3.new(8, 0.5, 5), move = "LowWheel"},
	{pos = Vector3.new(0, 1.5, 14), move = "RearOrbit"},
	{pos = Vector3.new(-2, 0.8, -15), move = "FrontDriveBy"}
}
local usedOffsets = {}

-- Sanfter Bildübergang
local function fade(inOut)
	local target = inOut and 0 or 1
	local info = TweenInfo.new(0.4, Enum.EasingStyle.Quad)
	local tween = TweenService:Create(fadeFrame, info, {BackgroundTransparency = target})
	tween:Play()
	return tween
end

local function stopCinematic()
	isCinematic = false
	fadeFrame.BackgroundTransparency = 1 -- Sofort-Reset bei Bewegung
	camera.CameraType = Enum.CameraType.Custom
end

local function startCinematic()
	if isCinematic then return end
	isCinematic = true
	camera.CameraType = Enum.CameraType.Scriptable
	
	task.spawn(function()
		while isCinematic do
			local char = player.Character
			local root = char and char:FindFirstChild("HumanoidRootPart")
			
			if root and isCinematic then
				-- Anti-Repeat Logik
				if #usedOffsets == #offsets then usedOffsets = {} end
				local randomIndex
				repeat
					randomIndex = math.random(1, #offsets)
				until not table.find(usedOffsets, randomIndex)
				
				table.insert(usedOffsets, randomIndex)
				local choice = offsets[randomIndex]
				
				local tIn = fade(true)
				tIn.Completed:Wait()
				
				if not isCinematic then break end
				
				local startTime = tick()
				local duration = 4.5
				local connection
				
				connection = RunService.RenderStepped:Connect(function()
					if not isCinematic then 
						connection:Disconnect() 
						return 
					end
					
					local elapsed = tick() - startTime
					local alpha = elapsed / duration
					local targetPos = root.Position
					
					local currentPos
					if choice.move == "Orbit" then
						local angle = alpha * math.pi * 0.5
						currentPos = targetPos + Vector3.new(math.cos(angle)*12, 2, math.sin(angle)*12)
					elseif choice.move == "ZoomIn" then
						currentPos = targetPos + choice.pos:Lerp(choice.pos * 0.5, alpha)
					elseif choice.move == "TopDown" then
						currentPos = targetPos + choice.pos + Vector3.new(0, -alpha * 3, 0)
					elseif choice.move == "RearOrbit" then
						local angle = (alpha - 0.5) * math.pi * 0.3
						currentPos = targetPos + Vector3.new(math.sin(angle)*14, 1.5, math.cos(angle)*14)
					elseif choice.move == "FrontDriveBy" then
						currentPos = targetPos + choice.pos:Lerp(choice.pos + Vector3.new(4, 0, 8), alpha)
					else
						currentPos = targetPos + choice.pos + Vector3.new(alpha * 5, 0, 0)
					end
					
					camera.CFrame = CFrame.new(currentPos, targetPos)
				end)
				
				fade(false)
				task.wait(duration - 0.8)
				
				if isCinematic then
					local tOut = fade(true)
					tOut.Completed:Wait()
				end
				connection:Disconnect()
			else
				task.wait(1)
			end
		end
	end)
end

-- AFK Check & Bewegung (15 SEKUNDEN TIMER)
RunService.Heartbeat:Connect(function()
	local char = player.Character
	local hum = char and char:FindFirstChild("Humanoid")
	
	local isMoving = hum and (hum.MoveDirection.Magnitude > 0)
	local isKeyDown = UIS:IsKeyDown(Enum.KeyCode.W) or UIS:IsKeyDown(Enum.KeyCode.A) or UIS:IsKeyDown(Enum.KeyCode.S) or UIS:IsKeyDown(Enum.KeyCode.D)

	if isMoving or isKeyDown then
		if isCinematic then
			stopCinematic()
		end
		lastInputTime = tick()
	end
	
	-- Hier sind die 15 Sekunden eingestellt
	if tick() - lastInputTime > 15 and not isCinematic then
		startCinematic()
	end
end)

UIS.InputBegan:Connect(function() lastInputTime = tick() end)
