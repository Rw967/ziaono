-- KLASSISCHES KREUZ ELEMENTE
local crossLines = {
    T = Drawing.new("Line"),
    B = Drawing.new("Line"),
    L = Drawing.new("Line"),
    R = Drawing.new("Line")
}

for _, v in pairs(crossLines) do v.Visible = false v.Transparency = 1 end

-- CROSSHAIR UPDATE FUNKTION (NUR KLASSISCH)
local function updateCrosshair()
    if not _G.ShowCrosshair then
        for _, v in pairs(crossLines) do v.Visible = false end
        return
    end

    local center = camera.ViewportSize / 2
    local s = _G.CrosshairSize
    local t = _G.CrosshairThickness
    local c = _G.CrosshairColor

    -- Oben
    crossLines.T.From = center - Vector2.new(0, s)
    crossLines.T.To = center - Vector2.new(0, 2)
    -- Unten
    crossLines.B.From = center + Vector2.new(0, s)
    crossLines.B.To = center + Vector2.new(0, 2)
    -- Links
    crossLines.L.From = center - Vector2.new(s, 0)
    crossLines.L.To = center - Vector2.new(2, 0)
    -- Rechts
    crossLines.R.From = center + Vector2.new(s, 0)
    crossLines.R.To = center + Vector2.new(2, 0)

    for _, v in pairs(crossLines) do
        v.Visible = true
        v.Color = c
        v.Thickness = t
    end
end

-- AIMBOT TARGET FUNKTION
local function getClosestPlayer()
    local target, dist = nil, _G.FOV
    for _, v in pairs(game.Players:GetPlayers()) do
        if v ~= player and v.Character and v.Character:FindFirstChild(_G.AimPart) then
            local pos, onScreen = camera:WorldToViewportPoint(v.Character[_G.AimPart].Position)
            if onScreen then
                local mag = (Vector2.new(pos.X, pos.Y) - userInput:GetMouseLocation()).Magnitude
                if mag < dist then dist = mag target = v end
            end
        end
    end
    return target
end

