-- CROSSHAIR RENDER ENGINE (DETAILED)
-- ==========================================

local function RenderCrosshair()
    local screenCenter = camera.ViewportSize / 2
    local crossSize = _G.CrosshairSize
    local crossColor = _G.CrosshairColor
    local crossThick = _G.CrosshairThickness
    
    if _G.ShowCrosshair == true then
        local objects = ESP_Objects.Crosshair
        
        objects.Top.Visible = true
        objects.Top.From = screenCenter - Vector2.new(0, crossSize)
        objects.Top.To = screenCenter - Vector2.new(0, 2)
        objects.Top.Color = crossColor
        objects.Top.Thickness = crossThick

        objects.Bottom.Visible = true
        objects.Bottom.From = screenCenter + Vector2.new(0, crossSize)
        objects.Bottom.To = screenCenter + Vector2.new(0, 2)
        objects.Bottom.Color = crossColor
        objects.Bottom.Thickness = crossThick

        objects.Left.Visible = true
        objects.Left.From = screenCenter - Vector2.new(crossSize, 0)
        objects.Left.To = screenCenter - Vector2.new(2, 0)
        objects.Left.Color = crossColor
        objects.Left.Thickness = crossThick

        objects.Right.Visible = true
        objects.Right.From = screenCenter + Vector2.new(crossSize, 0)
        objects.Right.To = screenCenter + Vector2.new(2, 0)
        objects.Right.Color = crossColor
        objects.Right.Thickness = crossThick
    else
        ESP_Objects.Crosshair.Top.Visible = false
        ESP_Objects.Crosshair.Bottom.Visible = false
        ESP_Objects.Crosshair.Left.Visible = false
        ESP_Objects.Crosshair.Right.Visible = false
    end
end

