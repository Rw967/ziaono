RunService.RenderStepped:Connect(function()
    
    -- HUD Updates
    ESP_Objects.FOVCircle.Visible = _G.ShowFOV
    ESP_Objects.FOVCircle.Position = UserInputService:GetMouseLocation()
    ESP_Objects.FOVCircle.Radius = _G.FOVRadius
    ESP_Objects.FOVCircle.Color = _G.FOVColor
    
    RenderCrosshair()

    -- NEU: INFINITE JUMP (HOLD LOGIC)
    if _G.InfiniteJump and UserInputService:IsKeyDown(Enum.KeyCode.Space) then
        if character and character:FindFirstChild("Humanoid") then
            character.Humanoid:ChangeState(Enum.HumanoidStateType.Jumping)
        end
    end

    -- Movement Handling
    if _G.NoClip then
        if character then
            for _, p in pairs(character:GetDescendants()) do
                if p:IsA("BasePart") then p.CanCollide = false end
            end
        end
    end
    
    if character and character:FindFirstChild("Humanoid") then
        if not _G.Flying then
            character.Humanoid.WalkSpeed = _G.WalkSpeed
            character.Humanoid.JumpPower = _G.JumpPower
        end
    end

    -- AIMBOT LOGIC (REPAIRED MATH)
    if _G.AimbotEnabled and UserInputService:IsMouseButtonPressed(_G.AimbotKey) then
        if _G.AimbotTarget == nil then _G.AimbotTarget = GetClosestTarget() end
        if _G.AimbotTarget and _G.AimbotTarget.Character then
            local head = _G.AimbotTarget.Character:FindFirstChild("Head")
            if head then
                local tScreen = camera:WorldToViewportPoint(head.Position)
                local mLoc = UserInputService:GetMouseLocation()
                
                -- Stabilisierte Division (Kein Spinnen bei 6-7 mehr)
                local safeSmooth = math.max(_G.Smoothing, 1)
                local diffX = (tScreen.X - mLoc.X) / safeSmooth
                local diffY = (tScreen.Y - mLoc.Y) / safeSmooth
                
                mousemoverel(diffX, diffY)
            end
        end
    else _G.AimbotTarget = nil end

    -- FLIGHT ENGINE V4 (THE GLIDE)
    if _G.Flying and character and character:FindFirstChild("HumanoidRootPart") then
        local hrp = character.HumanoidRootPart
        local hum = character:FindFirstChild("Humanoid")
        if hum then hum.PlatformStand = true end
        
        local dir = Vector3.new(0, 0, 0)
        if UserInputService:IsKeyDown(Enum.KeyCode.W) then dir = dir + camera.CFrame.LookVector end
        if UserInputService:IsKeyDown(Enum.KeyCode.S) then dir = dir - camera.CFrame.LookVector end
        if UserInputService:IsKeyDown(Enum.KeyCode.A) then dir = dir - camera.CFrame.RightVector end
        if UserInputService:IsKeyDown(Enum.KeyCode.D) then dir = dir + camera.CFrame.RightVector end
        if UserInputService:IsKeyDown(Enum.KeyCode.Space) then dir = dir + Vector3.new(0, 1, 0) end
        if UserInputService:IsKeyDown(Enum.KeyCode.LeftShift) then dir = dir - Vector3.new(0, 1, 0) end
        
        -- The "Strange" Professional Glide Logic
        hrp.Velocity = dir * _G.FlySpeed
        hrp.RotVelocity = Vector3.new(0,0,0) -- No spinning
    else
        if character and character:FindFirstChild("Humanoid") then
            character.Humanoid.PlatformStand = false
        end
    end

    -- ESP SYSTEM (STAYS SAME)
    local allP = Players:GetPlayers()
    for j = 1, #allP do
        local otherPlayer = allP[j]
        if otherPlayer ~= player and otherPlayer.Character and otherPlayer.Character:FindFirstChild("HumanoidRootPart") then
            local targetHRP = otherPlayer.Character.HumanoidRootPart
            local targetHum = otherPlayer.Character:FindFirstChild("Humanoid")
            local screenPos, onScreen = camera:WorldToViewportPoint(targetHRP.Position)
            
            -- Highlight
            if _G.HighlightESP then
                local h = otherPlayer.Character:FindFirstChild("ezHighlight") or Instance.new("Highlight", otherPlayer.Character)
                h.Name = "ezHighlight"; h.FillColor = _G.HighlightColor
            else
                local h = otherPlayer.Character:FindFirstChild("ezHighlight")
                if h then h:Destroy() end
            end

            if onScreen then
                -- Tracers
                if _G.TracersEnabled then
                    local tr = ESP_Objects.Tracers[otherPlayer.Name] or Drawing.new("Line")
                    ESP_Objects.Tracers[otherPlayer.Name] = tr
                    tr.Visible = true; tr.Color = _G.TracerColor; tr.Thickness = _G.TracerThickness
                    local s; if _G.TracerOrigin == "Top" then s = Vector2.new(camera.ViewportSize.X/2, 0) elseif _G.TracerOrigin == "Center" then s = camera.ViewportSize/2 else s = Vector2.new(camera.ViewportSize.X/2, camera.ViewportSize.Y) end
                    tr.From = s; tr.To = Vector2.new(screenPos.X, screenPos.Y)
                elseif ESP_Objects.Tracers[otherPlayer.Name] then ESP_Objects.Tracers[otherPlayer.Name].Visible = false end

                -- Boxes
                if _G.BoxESP then
                    local bx = ESP_Objects.Boxes[otherPlayer.Name] or Drawing.new("Square")
                    ESP_Objects.Boxes[otherPlayer.Name] = bx
                    bx.Visible = true; bx.Color = _G.BoxColor; bx.Thickness = _G.BoxThickness
                    bx.Size = Vector2.new(_G.BoxWidth / screenPos.Z, _G.BoxHeight / screenPos.Z)
                    bx.Position = Vector2.new(screenPos.X - bx.Size.X/2, screenPos.Y - bx.Size.Y/2)
                elseif ESP_Objects.Boxes[otherPlayer.Name] then ESP_Objects.Boxes[otherPlayer.Name].Visible = false end

                -- Text
                if _G.NameESP or _G.HealthESP or _G.DistanceESP then
                    local txt = ESP_Objects.Names[otherPlayer.Name] or Drawing.new("Text")
                    ESP_Objects.Names[otherPlayer.Name] = txt
                    txt.Visible = true; txt.Center = true; txt.Outline = true; txt.Size = _G.TextSize; txt.Color = _G.ESPTextColor
                    local b = ""
                    if _G.NameESP then b = b .. otherPlayer.DisplayName .. "\n" end
                    if _G.HealthESP and targetHum then b = b .. "HP: " .. math.floor(targetHum.Health) .. "%\n" end
                    if _G.DistanceESP then b = b .. "[" .. math.floor((character.HumanoidRootPart.Position - targetHRP.Position).Magnitude) .. "m]" end
                    txt.Text = b; txt.Position = Vector2.new(screenPos.X, screenPos.Y - (_G.BoxHeight / 2 / screenPos.Z) - 75)
                elseif ESP_Objects.Names[otherPlayer.Name] then ESP_Objects.Names[otherPlayer.Name].Visible = false end
            else
                if ESP_Objects.Boxes[otherPlayer.Name] then ESP_Objects.Boxes[otherPlayer.Name].Visible = false end
                if ESP_Objects.Names[otherPlayer.Name] then ESP_Objects.Names[otherPlayer.Name].Visible = false end
                if ESP_Objects.Tracers[otherPlayer.Name] then ESP_Objects.Tracers[otherPlayer.Name].Visible = false end
            end
        end
    end
end)

