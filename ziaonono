local function RenderCrosshair()
    local center = camera.ViewportSize / 2
    local size = _G.CrosshairSize
    local color = _G.CrosshairColor
    local thick = _G.CrosshairThickness
    local ch = ESP_Objects.Crosshair
    
    if _G.ShowCrosshair == true then
        ch.Top.Visible = true; ch.Top.From = center - Vector2.new(0, size); ch.Top.To = center - Vector2.new(0, 2); ch.Top.Color = color; ch.Top.Thickness = thick
        ch.Bottom.Visible = true; ch.Bottom.From = center + Vector2.new(0, size); ch.Bottom.To = center + Vector2.new(0, 2); ch.Bottom.Color = color; ch.Bottom.Thickness = thick
        ch.Left.Visible = true; ch.Left.From = center - Vector2.new(size, 0); ch.Left.To = center - Vector2.new(2, 0); ch.Left.Color = color; ch.Left.Thickness = thick
        ch.Right.Visible = true; ch.Right.From = center + Vector2.new(size, 0); ch.Right.To = center + Vector2.new(2, 0); ch.Right.Color = color; ch.Right.Thickness = thick
    else
        ch.Top.Visible = false; ch.Bottom.Visible = false; ch.Left.Visible = false; ch.Right.Visible = false
    end
end

