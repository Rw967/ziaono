local function GetClosestTarget()
    local nearestTarget = nil
    local maxDist = _G.FOVRadius
    
    local playersList = Players:GetPlayers()
    
    for i = 1, #playersList do
        local targetPlayer = playersList[i]
        
        if targetPlayer ~= player then
            if targetPlayer.Character then
                -- AimPart entfernt: Standardmäßig auf den Kopf (Head) fixiert
                local head = targetPlayer.Character:FindFirstChild("Head")
                local hum = targetPlayer.Character:FindFirstChild("Humanoid")
                
                if head and hum and hum.Health > 0 then
                    local screenPos, onScreen = camera:WorldToViewportPoint(head.Position)
                    
                    if onScreen then
                        local mousePos = UserInputService:GetMouseLocation()
                        local diffX = screenPos.X - mousePos.X
                        local diffY = screenPos.Y - mousePos.Y
                        local distToMouse = math.sqrt(diffX^2 + diffY^2)
                        
                        if distToMouse < maxDist then
                            maxDist = distToMouse
                            nearestTarget = targetPlayer
                        end
                    end
                end
            end
        end
    end
    return nearestTarget
end

local function ApplyNoClip()
    if _G.NoClip == true then
        if character ~= nil then
            local children = character:GetDescendants()
            for i = 1, #children do
                local part = children[i]
                if part:IsA("BasePart") then
                    part.CanCollide = false
                end
            end
        end
    end
end

