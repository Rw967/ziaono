})

-- SERVICES
local player = game.Players.LocalPlayer
local camera = workspace.CurrentCamera
local runService = game:GetService("RunService")
local userInput = game:GetService("UserInputService")

-- SETTINGS
_G.AimbotEnabled = false
_G.Wallbang = false
_G.AimPart = "Head"
_G.Smoothing = 1
_G.FOV = 150 -- Das wird jetzt über den Slider gesteuert
_G.WalkSpeed = 16
_G.JumpPower = 50 -- Neu hinzugefügt
_G.FlySpeed = 50
_G.Flying = false
_G.NoClip = false
_G.Visuals = false
_G.ESPColor = Color3.fromRGB(255, 0, 0)

-- NEUE CAMERA SETTINGS
_G.MaxZoom = 128
_G.ForceThirdPerson = false

local tracers = {}
local fovCircle = Drawing.new("Circle")
fovCircle.Visible = false
fovCircle.Thickness = 1
fovCircle.Radius = _G.FOV
fovCircle.Color = _G.ESPColor

-- AIMBOT TARGET FUNKTION
local function getClosestPlayer()
    local target = nil
    local dist = _G.FOV
    for _, v in pairs(game.Players:GetPlayers()) do
        if v ~= player and v.Character and v.Character:FindFirstChild(_G.AimPart) then
            if not _G.Wallbang then
                local ray = Ray.new(camera.CFrame.Position, (v.Character[_G.AimPart].Position - camera.CFrame.Position).Unit * 500)
                local hit = workspace:FindPartOnRayWithIgnoreList(ray, {player.Character})
                if hit and not hit:IsDescendantOf(v.Character) then continue end
            end
            local pos, onScreen = camera:WorldToViewportPoint(v.Character[_G.AimPart].Position)
            if onScreen then
                local magnitude = (Vector2.new(pos.X, pos.Y) - userInput:GetMouseLocation()).Magnitude
                if magnitude < dist then dist = magnitude target = v end
            end
        end
    end
    return target
end

