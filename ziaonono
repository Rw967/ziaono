-- ==========================================
-- MAIN ENGINE
-- ==========================================
runService.RenderStepped:Connect(function()
    fovCircle.Position = userInput:GetMouseLocation()
    updateCrosshair()

    -- Camera
    player.CameraMaxZoomDistance = _G.MaxZoom
    if _G.ForceThirdPerson then
        player.CameraMode = Enum.CameraMode.Classic
        if player.CameraMinZoomDistance < 5 then player.CameraMinZoomDistance = 5 end
    else
        player.CameraMinZoomDistance = 0.5
    end

    -- Aimbot
    if _G.AimbotEnabled and userInput:IsMouseButtonPressed(Enum.UserInputType.MouseButton2) then
        local t = getClosestPlayer()
        if t then camera.CFrame = camera.CFrame:Lerp(CFrame.new(camera.CFrame.Position, t.Character[_G.AimPart].Position), 1/_G.Smoothing) end
    end

    -- Movement
    if player.Character and player.Character:FindFirstChild("Humanoid") then
        if not _G.Flying then 
            player.Character.Humanoid.WalkSpeed = _G.WalkSpeed 
            player.Character.Humanoid.JumpPower = _G.JumpPower
        end
        if _G.NoClip then for _, p in pairs(player.Character:GetDescendants()) do if p:IsA("BasePart") then p.CanCollide = false end end end
    end

    -- ESP
    if _G.Visuals then
        for _, p in pairs(game.Players:GetPlayers()) do
            if p ~= player and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
                local h = p.Character:FindFirstChild("ESP_H") or Instance.new("Highlight", p.Character)
                h.Name = "ESP_H"; h.FillColor = _G.ESPColor; h.Enabled = true
                local pos, onScreen = camera:WorldToViewportPoint(p.Character.HumanoidRootPart.Position)
                if onScreen then
                    if not tracers[p.Name] then tracers[p.Name] = Drawing.new("Line") end
                    tracers[p.Name].Visible = true; tracers[p.Name].From = Vector2.new(camera.ViewportSize.X/2, camera.ViewportSize.Y); tracers[p.Name].To = Vector2.new(pos.X, pos.Y); tracers[p.Name].Color = _G.ESPColor
                else if tracers[p.Name] then tracers[p.Name].Visible = false end end
            end
        end
    else
        for _, t in pairs(tracers) do t.Visible = false end
        for _, p in pairs(game.Players:GetPlayers()) do
            if p.Character and p.Character:FindFirstChild("ESP_H") then p.Character.ESP_H:Destroy() end
        end
    end
end)

-- CLICK TP LOGIK
userInput.InputBegan:Connect(function(input, processed)
    if processed or not _G.ClickTP then return end
    if input.UserInputType == Enum.UserInputType.MouseButton1 and userInput:IsKeyDown(Enum.KeyCode.LeftControl) then
        local ray = camera:ViewportPointToRay(mouse.X, mouse.Y)
        local result = workspace:Raycast(ray.Origin, ray.Direction * 1000)
        if result and player.Character then player.Character:MoveTo(result.Position + Vector3.new(0,3,0)) end
    end
end)
