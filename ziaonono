        local hum = character.Humanoid
        if _G.Flying == false then
            hum.WalkSpeed = _G.WalkSpeed
            hum.JumpPower = _G.JumpPower
        end
    end

    -- 3. Aimbot Logic Fix (New Lock System)
    if _G.AimbotEnabled == true then
        if UserInputService:IsMouseButtonPressed(_G.AimbotKey) then
            if _G.AimbotTarget == nil then
                _G.AimbotTarget = GetClosestTarget()
            end
            
            if _G.AimbotTarget ~= nil then
                if _G.AimbotTarget.Character then
                    -- Permanent fixiert auf Head
                    local part = _G.AimbotTarget.Character:FindFirstChild("Head")
                    if part then
                        local tPos = camera:WorldToViewportPoint(part.Position)
                        local mLoc = UserInputService:GetMouseLocation()
                        
                        local moveX = (tPos.X - mLoc.X) / _G.Smoothing
                        local moveY = (tPos.Y - mLoc.Y) / _G.Smoothing
                        
                        mousemoverel(moveX, moveY)
                    end
                end
            end
        else
            _G.AimbotTarget = nil
        end
    end

    -- 4. Flight Implementation
    if _G.Flying == true then
        if character ~= nil then
            local hrp = character:FindFirstChild("HumanoidRootPart")
            if hrp then
                local flyDirection = Vector3.new(0, 0, 0)
                if UserInputService:IsKeyDown(Enum.KeyCode.W) then
                    flyDirection = flyDirection + camera.CFrame.LookVector
                end
                if UserInputService:IsKeyDown(Enum.KeyCode.S) then
                    flyDirection = flyDirection - camera.CFrame.LookVector
                end
                if UserInputService:IsKeyDown(Enum.KeyCode.A) then
                    flyDirection = flyDirection - camera.CFrame.RightVector
                end
                if UserInputService:IsKeyDown(Enum.KeyCode.D) then
                    flyDirection = flyDirection + camera.CFrame.RightVector
                end
                hrp.Velocity = flyDirection * _G.FlySpeed
            end
        end
    end

    -- 5. ESP System (The core visual loop)
    local allPlayers = Players:GetPlayers()
    for j = 1, #allPlayers do
        local p = allPlayers[j]
        
        if p ~= player then
            if p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
                local root = p.Character.HumanoidRootPart
                local hum = p.Character:FindFirstChild("Humanoid")
                local pos, onScreen = camera:WorldToViewportPoint(root.Position)
                
                -- Highlight Logic
                if _G.HighlightESP == true then
                    local high = p.Character:FindFirstChild("ezsio_Highlight")
                    if not high then
                        high = Instance.new("Highlight", p.Character)
                        high.Name = "ezsio_Highlight"
                    end
                    high.FillColor = _G.HighlightColor
                else
                    local high = p.Character:FindFirstChild("ezsio_Highlight")
                    if high then high:Destroy() end
                end

                if onScreen then
                    -- Tracer Logic (Linien)
                    if _G.TracersEnabled then
                        local tracer = ESP_Objects.Tracers[p.Name] or Drawing.new("Line")
                        ESP_Objects.Tracers[p.Name] = tracer
                        tracer.Visible = true
                        tracer.Color = _G.TracerColor
                        tracer.Thickness = _G.TracerThickness
                        
                        local start
                        if _G.TracerOrigin == "Top" then start = Vector2.new(camera.ViewportSize.X / 2, 0)
                        elseif _G.TracerOrigin == "Center" then start = Vector2.new(camera.ViewportSize.X / 2, camera.ViewportSize.Y / 2)
                        else start = Vector2.new(camera.ViewportSize.X / 2, camera.ViewportSize.Y) end
                        
                        tracer.From = start
                        tracer.To = Vector2.new(pos.X, pos.Y)
                    elseif ESP_Objects.Tracers[p.Name] then
                        ESP_Objects.Tracers[p.Name].Visible = false
                    end

                    -- Render Boxes
                    if _G.BoxESP == true then
                        local box = ESP_Objects.Boxes[p.Name] or Drawing.new("Square")
                        ESP_Objects.Boxes[p.Name] = box
                        box.Visible = true
                        box.Color = _G.BoxColor
                        box.Size = Vector2.new(_G.BoxWidth / pos.Z, _G.BoxHeight / pos.Z)
                        box.Position = Vector2.new(pos.X - box.Size.X / 2, pos.Y - box.Size.Y / 2)
                    else
                        if ESP_Objects.Boxes[p.Name] then ESP_Objects.Boxes[p.Name].Visible = false end
                    end

                    -- Render Text Information (VERBESSERT: OUTLINE & ABSTÄNDE)
                    if _G.NameESP or _G.HealthESP or _G.DistanceESP then
                        local tag = ESP_Objects.Names[p.Name] or Drawing.new("Text")
                        ESP_Objects.Names[p.Name] = tag
                        tag.Visible = true
                        tag.Center = true
                        tag.Outline = true
                        tag.OutlineColor = Color3.new(0,0,0)
                        tag.Size = 18 -- Lesbare Größe
                        tag.Color = _G.ESPTextColor
                        
                        local infoString = ""
                        if _G.NameESP then infoString = infoString .. p.DisplayName .. "\n" end
                        if _G.HealthESP and hum then 
                            local healthVal = math.floor(hum.Health)
                            infoString = infoString .. "HP: " .. healthVal .. "%\n" 
                        end
                        if _G.DistanceESP then
                            local d = (character.HumanoidRootPart.Position - root.Position).Magnitude
                            infoString = infoString .. "[" .. math.floor(d) .. "m]"
                        end
                        
                        tag.Text = infoString
                        tag.Position = Vector2.new(pos.X, pos.Y - (_G.BoxHeight / 2 / pos.Z) - 75)
                    else
                        if ESP_Objects.Names[p.Name] then ESP_Objects.Names[p.Name].Visible = false end
                    end
                else
                    -- Cleanup if not visible
                    if ESP_Objects.Boxes[p.Name] then ESP_Objects.Boxes[p.Name].Visible = false end
                    if ESP_Objects.Names[p.Name] then ESP_Objects.Names[p.Name].Visible = false end
                    if ESP_Objects.Tracers[p.Name] then ESP_Objects.Tracers[p.Name].Visible = false end
                end
            end
        end
    end
end)

